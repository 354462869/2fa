{
  "manifest_version": 3,
  "name": "2FA 验证器",
  "version": "0.1.3",
  "description": "安全、可自托管、离线优先且支持端到端加密的 2FA 管理器。",
  "permissions": [
    "storage",
    "alarms",
    "unlimitedStorage",
    "sidePanel",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
