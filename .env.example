# ============================================================
# 2FA self-host MVP - example environment
# ------------------------------------------------------------
# Copy this file to `.env` (root) and/or service-specific
# `.env` files, then fill in your own values.  Never commit
# secrets.  Production secrets must be managed by your
# deployment system, not by this file.
# ============================================================

# ---------- Server (cmd/server) ----------

# Address the HTTP API listens on.
SERVER_ADDR=127.0.0.1:8080

# Logical environment name. Used only for log tagging.
SERVER_ENV=development

# SQLite database file path. Created on first run if missing.
SERVER_DB_PATH=./data/2fa.sqlite

# Public origin of the API (used for CORS, links).
# In dev this is the dev server; in prod this should be HTTPS.
SERVER_PUBLIC_ORIGIN=http://127.0.0.1:8080

# Secret used to sign session tokens.  REQUIRED in prod.
# Generate with: openssl rand -base64 48
# Leave empty in this example - never commit a real value.
SERVER_SESSION_SECRET=

# How long a server-side session is valid (Go duration syntax).
SERVER_SESSION_TTL=720h

# Optional admin bootstrap (only used on first start when the
# users table is empty).  The admin's password is hashed at
# rest; do not put real credentials in this example file.
SERVER_BOOTSTRAP_ADMIN_USERNAME=
SERVER_BOOTSTRAP_ADMIN_PASSWORD=

# Comma-separated list of allowed extension/admin origins for CORS.
SERVER_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Rate limit knobs (requests per minute per IP / per user).
SERVER_RATE_LIMIT_AUTH_PER_MIN=20
SERVER_RATE_LIMIT_SYNC_PER_MIN=600

# ---------- Web admin (apps/admin) ----------

# Public API base URL the admin SPA talks to.
VITE_API_BASE_URL=http://127.0.0.1:8080

# ---------- Browser extension (apps/extension) ----------

# Default API base URL pre-filled in the extension settings UI.
# The end user can still override this at runtime.
EXT_DEFAULT_API_BASE_URL=http://127.0.0.1:8080
